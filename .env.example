# ──────────────────────────────────────────
# PostgreSQL
# ──────────────────────────────────────────
POSTGRES_DB=netbox
POSTGRES_USER=netbox
POSTGRES_PASSWORD=change-me-postgres

# ──────────────────────────────────────────
# Redis
# ──────────────────────────────────────────
REDIS_PASSWORD=change-me-redis

# ──────────────────────────────────────────
# Netbox
# ──────────────────────────────────────────
ALLOWED_HOSTS=localhost 127.0.0.1

DB_HOST=postgres
DB_PORT=5432
DB_NAME=netbox
DB_USER=netbox
DB_PASSWORD=change-me-postgres

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_CACHE_HOST=redis
REDIS_CACHE_PORT=6379
REDIS_CACHE_PASSWORD=change-me-redis
REDIS_CACHE_DATABASE=1

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-generate-a-real-secret-key

SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@ztp-framework.local
SUPERUSER_PASSWORD=change-me-netbox-admin

# ──────────────────────────────────────────
# Grafana
# ──────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin
